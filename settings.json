{
  "asciidoc.extensions.enableKroki": true,
  "cSpell.language": "en,de",
  "cSpell.userWords": [
    "adoc",
    "Agiledrop",
    "Anreisewidget",
    "Audiostream",
    "Barrierefreiheitsanforderungen",
    "Barrierefreiheitsstärkungsgesetz",
    "BFSG",
    "Clientzertifikate",
    "Cloudbetrieb",
    "commitlint",
    "DBFV",
    "deployen",
    "Dotfiles",
    "dpunkt",
    "DSGVO",
    "Entra",
    "GIFs",
    "Gitlab",
    "Grafana",
    "hardwaregebundende",
    "Hardwaregebundene",
    "installable",
    "Interaktionsprozesses",
    "internetexponierte",
    "invalidieren",
    "koppenhagen",
    "modularization",
    "networkidle",
    "netzwerktechnisch",
    "OIDC",
    "Partnerspezifische",
    "pinia",
    "plantuml",
    "Portfoliosteuerung",
    "protokollierbar",
    "Querschnittliche",
    "Reisendeninformation",
    "Riedbahn",
    "Riedbahnsperrung",
    "runbook",
    "Runbook",
    "Runbooks",
    "screencasts",
    "Screenreader",
    "Scully",
    "Securityanalyse",
    "seheingeschränkte",
    "seheingeschränkten",
    "Sharepoint",
    "Styleguide",
    "Systel",
    "Threatmodelling",
    "Videocallanfrage",
    "Videocallclient",
    "Volkmer",
    "Webcomponents",
    "Whitelabel"
  ],
  "chat.editing.alwaysSaveWithGeneratedChanges": true,
  "code-review.groupBy": "priority",
  "code-review.reportWithCodeSelection": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "never",
    "source.organizeImports": "never"
  },
  "editor.formatOnSave": false,
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.rulers": [
    80,
    120,
    160
  ],
  "editor.showFoldingControls": "always",
  "editor.suggestSelection": "first",
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "indentRainbow.excludedLanguages": [
    "plaintext",
    "log"
  ],
  "javascript.updateImportsOnFileMove.enabled": "always",
  "jest.runMode": "on-demand",
  "markdown-preview-enhanced.plantumlServer": "https://gitlab-kroki-prd.gitlab.comp.db.de/plantuml/svg",
  "plantuml.server": "https://gitlab-kroki-prd.gitlab.comp.db.de/plantuml/svg",
  "redhat.telemetry.enabled": false,
  "telemetry.telemetryLevel": "off",
  "terminal.external.osxExec": "iTerm2.app",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.env.osx": {
    "FIG_NEW_SESSION": "1"
  },
  "terminal.integrated.fontFamily": "Hack Nerd Font",
  "terminal.integrated.fontSize": 14,
  "update.showReleaseNotes": false,
  "window.zoomLevel": 1
}
