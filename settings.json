{
  "[dockercompose]": {
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.insertSpaces": true,
    "editor.quickSuggestions": {
      "comments": false,
      "other": true,
      "strings": true
    },
    "editor.tabSize": 2
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "diffEditor.ignoreTrimWhitespace": true
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.formatOnSave": false
  },
  "[typescriptreact]": {
    "editor.formatOnSave": false
  },
  "[yaml]": {
    "diffEditor.ignoreTrimWhitespace": true
  },
  "asciidoc.extensions.enableKroki": true,
  "cSpell.language": "en,de",
  "cSpell.userWords": [
    "adoc",
    "Audiostream",
    "Barrierefreiheitsanforderungen",
    "Barrierefreiheitsstärkungsgesetz",
    "BFSG",
    "Clientzertifikate",
    "Cloudbetrieb",
    "commitlint",
    "DBFV",
    "deployen",
    "deployt",
    "Dotfiles",
    "dpunkt",
    "DSGVO",
    "Entra",
    "GIFs",
    "gitlab",
    "Gitlab",
    "Grafana",
    "Hardwaregebundene",
    "installable",
    "Interaktionsprozesses",
    "internetexponierte",
    "invalidieren",
    "joinen",
    "konfigurative",
    "Koppenhagen",
    "minifizierten",
    "Minifizierung",
    "Mitigationsmaßnahmen",
    "Mitigierung",
    "modularization",
    "networkidle",
    "netzwerktechnisch",
    "OIDC",
    "Partnerspezifische",
    "Pilotierung",
    "pinia",
    "plantuml",
    "Portfoliosteuerung",
    "protokollierbar",
    "Querschnittliche",
    "Reisendeninformation",
    "runbook",
    "Runbook",
    "Runbooks",
    "screencasts",
    "screenreader",
    "Screenreader",
    "Scully",
    "Securityanalyse",
    "seheingeschränkte",
    "seheingeschränkten",
    "Sharepoint",
    "Sourcemaps",
    "Styleguide",
    "Systel",
    "Threatmodelling",
    "Umgebungsabhängiger",
    "Umsysteme",
    "unminifizierten",
    "Videocallanfrage",
    "Videocallclient",
    "WCAG",
    "Webcomponents",
    "Whitelabel"
  ],
  "chat.editing.alwaysSaveWithGeneratedChanges": true,
  "code-review.groupBy": "priority",
  "code-review.reportWithCodeSelection": true,
  "diffEditor.ignoreTrimWhitespace": true,
  "docker.extension.enableComposeLanguageServer": false,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "never",
    "source.organizeImports": "never"
  },
  "editor.formatOnSave": false,
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.rulers": [80, 120, 160],
  "editor.showFoldingControls": "always",
  "editor.suggestSelection": "first",
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "git.blame.editorDecoration.enabled": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.ignoreRebaseWarning": true,
  "git.replaceTagsWhenPull": true,
  "gitlens.ai.generateCommitMessage.customInstructions": "Generate a commit message following conventional commit format. Try to infer the scope from the branche name (e. g. Ticket number or from the changes). The message body should be compact and meaningful but it is optional for trivial changes",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4o",
  "hediet.vscode-drawio.resizeImages": null,
  "indentRainbow.excludedLanguages": ["plaintext", "log"],
  "javascript.updateImportsOnFileMove.enabled": "always",
  "jest.runMode": "on-demand",
  "kiroAgent.agentAutonomy": "Autopilot",
  "kiroAgent.codeReferences.referenceTracker": true,
  "kiroAgent.commandDenylist": [
    "rm -rf",
    "sudo",
    "chmod 777",
    "eval",
    "curl | sh",
    "wget | sh",
    "> /dev/",
    "mkfs",
    "dd if="
  ],
  "kiroAgent.mcpApprovedEnvVars": ["workspaceFolder"],
  "kiroAgent.modelSelection": "auto",
  "kiroAgent.trustedCommands": [
    "python3 *",
    "ng test *",
    "npx nx *",
    "npx ng *",
    "ls *",
    "npm run *",
    "git diff *",
    "npx vitest *",
    "git log *",
    "sleep *",
    "grep *",
    "git stash *",
    "git branch *",
    "git fetch *",
    "npx tsc *",
    "git tag -l",
    "git show *",
    "npx prettier *",
    "find *",
    "npm install *",
    "rm -rf node_modules package-lock.json",
    "npm ls *",
    "npx stylelint *",
    "git status *",
    "playwright-cli *",
    "npx playwright *",
    "git rev-parse *",
    "head *",
    "xcodebuild *",
    "npx eslint *",
    "cat *",
    "cp *",
    "wc *",
    "npm view *",
    "pnpm install",
    "pnpm nx *",
    "pnpm add *",
    "oc logs *",
    "oc describe *",
    "oc get *",
    "glab ci view *",
    "glab ci trace *",
    "pnpm install *",
    "aws logs *",
    "glab api *",
    "glab auth status *",
    "glab ci list *",
    "glab ci get *",
    "glab ci artifact *",
    "glab job artifact *",
    "unzip *",
    "glab mr view *",
    "glab ci status *",
    "aws cloudformation describe-stacks *",
    "aws ecr describe-repositories *",
    "aws ecr describe-images *",
    "aws ecs list-services *",
    "aws ecr describe-services *",
    "glab mr diff *",
    "aws dynamodb *",
    "aws ssm *",
    "mkdir *",
    "node *",
    "npm test *",
    "cd *"
  ],
  "kiroAgent.trustedTools": ["webFetch", "remote_web_search", "web_fetch"],
  "liveshare.allowGuestTaskControl": true,
  "markdown-preview-enhanced.plantumlServer": "https://gitlab-kroki-prd.gitlab.comp.db.de/plantuml/svg",
  "markdownAdmonitions.enabld": true,
  "plantuml.server": "https://gitlab-kroki-prd.gitlab.comp.db.de/plantuml/svg",
  "redhat.telemetry.enabled": false,
  "telemetry.dataSharingAndPromptLogging.contentCollectionForServiceImprovement": true,
  "telemetry.dataSharingAndPromptLogging.promptLogging": false,
  "telemetry.dataSharingAndPromptLogging.usageAnalyticsAndPerformanceMetrics": true,
  "telemetry.telemetryLevel": "off",
  "terminal.external.osxExec": "iTerm2.app",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.env.osx": {
    "FIG_NEW_SESSION": "1",
    "Q_NEW_SESSION": "1"
  },
  "terminal.integrated.fontFamily": "Hack Nerd Font",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.sendKeybindingsToShell": true,
  "todo-tree.general.tags": [
    "BUG",
    "HACK",
    "FIXME",
    "Fixme",
    "FixMe",
    "@FIXME",
    "@Fixme",
    "@FixMe",
    "TODO",
    "ToDo",
    "Todo",
    "@TODO",
    "@ToDo",
    "@Todo",
    "@todo",
    "XXX",
    "[ ]",
    "[x]"
  ],
  "typescript.updateImportsOnFileMove.enabled": "always",
  "update.showReleaseNotes": false,
  "window.zoomLevel": 0.7,
  "workbench.editor.enablePreview": false,
  "workbench.iconTheme": "vscode-icons"
}
